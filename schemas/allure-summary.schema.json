{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AllureSummary",
  "description": "Schema for the allure-summary.json artifact — test execution counts.",
  "type": "object",
  "required": ["schema_version", "generated_at", "mode", "total", "passed", "failed", "skipped"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "passed": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "skipped": {
      "type": "integer",
      "minimum": 0
    },
    "reason": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
